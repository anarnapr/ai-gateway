# Comma-separated list of Gemini API keys. This is the single canonical env var name —
# do not add GEMINI_API / GEMINI_API_KEY variants, callers/config must use this one.
GEMINI_API_KEYS=your_key_1,your_key_2

# Redis connection used for shared pool state (cooldowns, in-flight caps, usage counters).
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=aiservice

# Global cap on concurrent in-flight requests across all workers/instances (Redis-coordinated).
MAX_IN_FLIGHT=4

# Default per-key requests-per-minute used by the pool's own bookkeeping (in addition to
# the per-model quota table in config/models.yaml).
DEFAULT_RPM=15

# Simple per-key throttle applied before every call.
RATE_LIMIT_MIN_INTERVAL_SECONDS=5.0
RATE_LIMIT_RPM=12

# Hard ceiling for any single cooldown placed on a key. Always clamped to <= 3600 regardless
# of this value.
DEAD_COOLDOWN_SECONDS=3600.0
LONG_TERM_THRESHOLD_SECONDS=3600.0

MODELS_CONFIG_PATH=config/models.yaml

LOG_DIR=tmp/ai/logs
UPLOADS_DIR=tmp/ai/uploads

# When true, persist full request/response payloads per-request under tmp/ai/logs/requests/.
# Off by default since prompts/media may be large or sensitive.
LOG_FULL_PAYLOADS=false
